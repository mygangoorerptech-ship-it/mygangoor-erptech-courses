<!doctype html>
<html>
<head>
  <meta charset="utf-8" />
  <title>Certificate</title>
  <style>
    body { margin: 0; padding: 0; }
    .certificate {
      width: 100%;
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: Arial, Helvetica, sans-serif;
    }
    .content {
      border: 5px double #333;
      padding: 2cm;
      width: 80%;
      text-align: center;
    }
    h1 { margin: 0; font-size: 32px; text-transform: uppercase; }
    h2 { margin: 20px 0 10px; font-size: 26px; }
    h3 { margin: 10px 0 20px; font-size: 20px; }
    p { margin: 5px 0; font-size: 16px; }
    .qr { margin-top: 20px; }
  </style>
</head>
<body>
  <div class="certificate">
    <div class="content">
      <h1>Certificate of Completion</h1>
      <p>This certifies that</p>
      <h2>{{student.name}}</h2>
      <p>has successfully completed</p>
      <h3>{{course.title}}</h3>
      {{#if course.chapterCount}}
        <p>Chapters: {{course.chapterCount}}</p>
      {{/if}}
      <p>Date: {{formatDate issuedOn "DD MMM YYYY"}}</p>
      <p>Issued by: {{issuer}}</p>
      <div class="qr">
        <img src="{{qrDataUrl}}" alt="QR Code" width="100" height="100" />
      </div>
    </div>
  </div>
</body>
</html>